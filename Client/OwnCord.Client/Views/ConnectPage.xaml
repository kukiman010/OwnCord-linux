<Page x:Class="OwnCord.Client.Views.ConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Connect">
    <Grid Background="#1e1f22">
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="380" Background="#2b2d31" CornerRadius="8" Padding="32">
            <StackPanel>
                <TextBlock Text="OwnCord" FontSize="24" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <!-- Server profile selector -->
                <TextBlock Text="Saved Servers" Foreground="#b5bac1" Margin="0,0,0,4"/>
                <ComboBox x:Name="ProfileCombo" DisplayMemberPath="Name"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          HorizontalAlignment="Stretch" Margin="0,0,0,16"/>

                <TextBlock Text="Server Address" Foreground="#b5bac1" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Username" Foreground="#b5bac1" Margin="0,0,0,4"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Password" Foreground="#b5bac1" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12"/>

                <!-- Invite code (register mode only) -->
                <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Invite Code" Foreground="#b5bac1" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>
                </StackPanel>

                <!-- Login / Register toggle -->
                <ToggleButton Content="Register mode"
                              IsChecked="{Binding IsRegisterMode}"
                              HorizontalAlignment="Left" Margin="0,0,0,16"/>

                <Button Content="Connect" Command="{Binding ConnectCommand}"
                        HorizontalAlignment="Stretch" Padding="0,10"
                        Background="#5865f2" Foreground="White" Click="ConnectButton_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Save Profile" Command="{Binding SaveProfileCommand}" Margin="0,0,8,0"/>
                    <Button Content="Delete" Command="{Binding DeleteProfileCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
